# Copy this file to .env and fill in your values

# Docker Hub image (default: eran12/home-browser:latest)
# IMAGE=eranei/home-browser:latest

# Your server's IP address or hostname (used to build clickable links)
# Examples:
#   SERVER_HOST=192.168.1.10
#   SERVER_HOST=myserver.local
#   SERVER_HOST=homelab.example.com
SERVER_HOST=localhost

# Port to expose the dashboard on (default: 8888)
PORT=8888

# How often the UI auto-refreshes in seconds (default: 30)
REFRESH_INTERVAL=30

# Host path for persistent custom links storage (default: ./data)
# DATA_DIR=./data
